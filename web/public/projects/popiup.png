<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Popiup - Smart Popup Links for Marketing Campaigns</title>
  <meta name="description"
    content="Create intelligent short links with customizable popup campaigns. Monetize your traffic while delivering exceptional user experiences." />

  <!-- SEO Meta Tags -->
  <meta name="keywords"
    content="popup links, short links, link monetization, marketing campaigns, conversion optimization, popup campaigns, link management, traffic monetization" />
  <meta name="author" content="Popiup" />
  <meta name="robots" content="index, follow" />
  <meta name="google-site-verification" content="ADD_YOUR_VERIFICATION_CODE_HERE" />

  <!-- Open Graph / Social Media Meta Tags -->
  <meta property="og:title" content="Popiup - Smart Popup Links for Marketing Campaigns" />
  <meta property="og:description"
    content="Create intelligent short links with customizable popup campaigns. Monetize your traffic while delivering exceptional user experiences." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://popiup.com" />
  <meta property="og:image" content="/og-image.png" />

  <!-- Twitter Card Meta Tags -->
  <meta name="twitter:card" content="summary_large_image" />
